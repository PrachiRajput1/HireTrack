<%- include('../partials/header') %>

<div class="container py-5">
    <div class="row">
        <div class="col-md-8">
            <div class="glass-card p-5 mb-4" style="background: var(--card-bg);">
                <div class="d-flex justify-content-between align-items-start mb-4">
                    <div>
                        <h2 class="fw-bold mb-1" style="color: var(--text-dark);"><%= job.title %></h2>
                        <p class="text-muted"><%= job.postedBy.company || 'HireTrack' %> &bull; <%= job.location %></p>
                    </div>
                    <% if(job.status === 'open') { %>
                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 fs-6 py-2 px-3">Open</span>
                    <% } else { %>
                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 fs-6 py-2 px-3">Closed</span>
                    <% } %>
                </div>
                
                <div class="d-flex flex-wrap gap-4 mb-5 pb-4 border-bottom">
                    <div>
                        <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.7rem; letter-spacing: 0.05em;">Department</small>
                        <strong style="color: var(--text-dark);"><i class="bi bi-diagram-3"></i> <%= job.department %></strong>
                    </div>
                    <div>
                        <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.7rem; letter-spacing: 0.05em;">Employment Type</small>
                        <strong style="color: var(--text-dark);"><i class="bi bi-clock-history"></i> <%= job.type %></strong>
                    </div>
                    <div>
                        <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.7rem; letter-spacing: 0.05em;">Work Model</small>
                        <strong style="color: var(--text-dark);"><i class="bi bi-laptop"></i> <%= job.workModel || 'On-site' %></strong>
                    </div>
                    <div>
                        <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.7rem; letter-spacing: 0.05em;">Experience</small>
                        <strong style="color: var(--text-dark);"><i class="bi bi-person-badge"></i> <%= job.experienceLevel || 'Mid Level' %></strong>
                    </div>
                    <div>
                        <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.7rem; letter-spacing: 0.05em;">Salary</small>
                        <strong style="color: var(--text-dark);"><i class="bi bi-cash"></i> <%= job.salaryRange || 'Not specified' %></strong>
                    </div>
                    <div>
                        <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.7rem; letter-spacing: 0.05em;">Posted On</small>
                        <strong style="color: var(--text-dark);"><i class="bi bi-calendar"></i> <%= new Date(job.createdAt).toLocaleDateString() %></strong>
                    </div>
                </div>

                <% if(job.skills && job.skills.length > 0) { %>
                    <h5 class="fw-bold mb-3" style="color: var(--brown);">Required Skills</h5>
                    <div class="d-flex flex-wrap gap-2 mb-5">
                        <% job.skills.forEach(skill => { %>
                            <span class="badge" style="background: var(--yellow-mid); color: var(--brown); font-size: 0.85rem; padding: 6px 12px; font-weight: 700; border-radius: 8px;"><%= skill %></span>
                        <% }) %>
                    </div>
                <% } %>

                <h5 class="fw-bold mb-3" style="color: var(--brown);">Job Description</h5>
                <p class="text-muted mb-5" style="white-space: pre-line; line-height: 1.8;"><%= job.description %></p>

                <h5 class="fw-bold mb-3" style="color: var(--brown);">Requirements</h5>
                <p class="text-muted" style="white-space: pre-line; line-height: 1.8;"><%= job.requirements %></p>
            </div>
        </div>

        <div class="col-md-4">
            <% if(currentUser.role === 'recruiter') { %>
                <div class="glass-card p-4 mb-4" style="background: var(--card-bg); border: 2px solid var(--border);">
                    <h5 class="fw-bold mb-1 text-center" style="color: var(--brown);">Analytics</h5>
                    <div class="text-center py-4">
                        <div class="display-3 fw-bold" style="color: var(--yellow-dark);"><%= typeof applicantCount !== 'undefined' ? applicantCount : 0 %></div>
                        <div class="text-muted text-uppercase fw-bold mt-2" style="font-size: 0.8rem; letter-spacing: 0.05em;">Total Applicants</div>
                    </div>
                </div>

                <div class="glass-card p-4" style="background: var(--card-bg);">
                    <h5 class="fw-bold mb-3" style="color: var(--brown);">Manage Job</h5>
                    <a href="/jobs/<%= job._id %>/edit" class="btn btn-outline-primary w-100 mb-2 fw-bold" style="border-color: var(--primary); color: var(--primary-hover);">Edit Job Details</a>
                    <form action="/jobs/<%= job._id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this job? This cannot be undone.');">
                        <button type="submit" class="btn btn-outline-danger w-100 fw-bold">Delete Job</button>
                    </form>
                </div>
            <% } else { %>
                <% if(job.status === 'open') { %>
                    <div class="glass-card p-4" style="background: var(--card-bg);">
                        <h5 class="fw-bold mb-4" style="color: var(--brown);">Apply for this job</h5>
                        <form action="/applicants/apply/<%= job._id %>" method="POST" enctype="multipart/form-data">
                            <div class="mb-3">
                                <label class="form-label">Resume (PDF only)</label>
                                <input type="file" name="resume" class="form-control" accept="application/pdf" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Years of Experience</label>
                                <input type="number" name="experience" class="form-control" min="0" required>
                            </div>
                            <div class="mb-4">
                                <label class="form-label">Skills (comma separated)</label>
                                <input type="text" name="skills" class="form-control" placeholder="JavaScript, React, Node.js">
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Submit Application</button>
                        </form>
                    </div>
                <% } else { %>
                    <div class="glass-card p-4 text-center">
                        <h5 class="text-muted mb-0">This job is no longer accepting applications.</h5>
                    </div>
                <% } %>
            <% } %>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
