<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"/>
  <link rel="stylesheet" href="/css/landing.css"/>
  <style>
    body { background: var(--cream); display: flex; flex-direction: column; min-height: 100vh; }
    .auth-page { flex: 1; display: flex; align-items: center; justify-content: center; padding: 40px 16px; }
    .auth-box {
      width: 100%; max-width: 440px;
      background: #fff; border-radius: 16px;
      border: 1.5px solid var(--border);
      box-shadow: var(--shadow-lg); padding: 40px;
    }
    .auth-logo { text-align: center; margin-bottom: 28px; }
    .auth-logo a { font-size: 1.5rem; font-weight: 800; color: var(--brown); text-decoration: none; }
    .auth-logo a span { color: var(--yellow-dark); }
    .auth-logo i { margin-right: 6px; }
    .auth-title { font-size: 1.4rem; font-weight: 800; color: var(--brown); margin-bottom: 6px; text-align: center; }
    .auth-sub { color: var(--text-muted); font-size: .9rem; text-align: center; margin-bottom: 28px; }
    .form-label { font-weight: 600; font-size: .85rem; color: var(--brown); margin-bottom: 5px; }
    .form-control, .form-select {
      border: 1.5px solid var(--border); border-radius: 8px;
      padding: 10px 14px; font-size: .9rem; font-family: inherit;
      background: var(--cream); color: var(--text); transition: border-color .2s;
    }
    .form-control:focus, .form-select:focus {
      border-color: var(--yellow-mid); box-shadow: 0 0 0 3px rgba(251,191,36,.15); outline: none;
    }
    .btn-auth {
      width: 100%; background: var(--yellow-mid); color: var(--brown);
      font-weight: 700; border: none; padding: 12px; border-radius: 8px;
      font-size: .95rem; cursor: pointer; transition: all .2s; margin-top: 4px;
    }
    .btn-auth:hover { background: var(--yellow-dark); color: #fff; transform: translateY(-1px); }
    .auth-link { text-align: center; margin-top: 20px; font-size: .87rem; color: var(--text-muted); }
    .auth-link a { color: var(--yellow-dark); font-weight: 600; text-decoration: none; }
    .auth-link a:hover { text-decoration: underline; }
    .alert-error {
      background: #fef2f2; border: 1.5px solid #fecaca; color: #b91c1c;
      border-radius: 8px; padding: 10px 14px; font-size: .87rem;
      margin-bottom: 20px; display: flex; align-items: center; gap: 8px;
    }
    .auth-top-nav {
      background: rgba(253,248,240,.95); backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--border); padding: 14px 5%;
      display: flex; justify-content: space-between; align-items: center;
    }
    .auth-top-nav a.logo { font-size: 1.1rem; font-weight: 800; color: var(--brown); text-decoration: none; }
    .auth-top-nav a.logo span { color: var(--yellow-dark); }
    .auth-top-nav a.back { font-size: .85rem; color: var(--text-muted); text-decoration: none; font-weight: 500; }
    .auth-top-nav a.back:hover { color: var(--brown); }
    .divider { display: flex; align-items: center; gap: 12px; margin: 20px 0; }
    .divider hr { flex: 1; border-color: var(--border); }
    .divider span { font-size: .8rem; color: var(--text-muted); white-space: nowrap; }
  </style>
</head>
<body>

<nav class="auth-top-nav">
  <a href="/" class="logo"><i class="bi bi-layers-fill"></i> Hire<span>Track</span></a>
  <a href="/" class="back"><i class="bi bi-arrow-left"></i> Back to Home</a>
</nav>

<div class="auth-page">
  <div class="auth-box">
    <div class="auth-title">Welcome back</div>
    <div class="auth-sub">Sign in to your HireTrack account</div>

    <% if(errorMsg) { %>
      <div class="alert-error"><i class="bi bi-exclamation-circle-fill"></i> <%= errorMsg %></div>
    <% } %>

    <form action="/auth/login" method="POST" novalidate>
      <div class="mb-3">
        <label class="form-label">Email address</label>
        <input type="email" name="email" class="form-control" required placeholder="you@company.com" autocomplete="email"/>
      </div>
      <div class="mb-4">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-control" required placeholder="••••••••" autocomplete="current-password"/>
      </div>
      <button type="submit" class="btn-auth">Sign In <i class="bi bi-arrow-right"></i></button>
    </form>

    <div class="divider"><hr/><span>or</span><hr/></div>

    <div class="auth-link">
      Don't have an account? <a href="/auth/register">Create one free</a>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
