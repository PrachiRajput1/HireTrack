<%- include('../partials/header') %>

<div class="container-fluid">
    <div class="row">
        <div class="col-md-2 p-0">
            <%- include('../partials/sidebar') %>
        </div>
        <div class="col-md-10 p-4">
            <div class="mb-4">
                <h2 class="fw-bold mb-1" style="color: var(--text-dark);">Candidate Pipeline</h2>
                <p class="text-muted">Track and manage candidates across all your job postings.</p>
            </div>
            
            <div class="kanban-board pb-4" style="display: flex; overflow-x: auto; gap: 1.25rem;">
                <% const stages = ['Applied', 'Screening', 'Technical Interview', 'HR Interview', 'Offer', 'Hired', 'Rejected']; %>
                
                <% stages.forEach(stage => { %>
                    <div class="kanban-column" style="min-width: 320px; background: var(--cream-dark); border: 1px solid var(--border); border-radius: 12px; padding: 1rem;">
                        <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom border-warning border-opacity-25">
                            <h6 class="fw-bold mb-0 text-uppercase" style="color: var(--brown); font-size: 0.8rem; letter-spacing: 0.05em;"><%= stage %></h6>
                            <span class="badge" style="background: var(--yellow-mid); color: var(--brown); font-size: 0.75rem;"><%= pipeline[stage] ? pipeline[stage].length : 0 %></span>
                        </div>
                        
                        <div class="kanban-cards-container d-flex flex-column gap-3" data-stage="<%= stage %>">
                            <% if(pipeline[stage] && pipeline[stage].length > 0) { %>
                                <% pipeline[stage].forEach(app => { %>
                                    <div class="kanban-card p-3 shadow-sm" style="background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border); transition: transform 0.2s;">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <div>
                                                <h6 class="mb-1 fw-bold" style="color: var(--text-dark);"><%= app.candidate.name %></h6>
                                                <span class="badge" style="background: var(--cream); color: var(--text-muted); border: 1px solid var(--border); font-size: 0.65rem;">
                                                    <i class="bi bi-briefcase me-1"></i><%= app.job.title %>
                                                </span>
                                            </div>
                                            <% if(app.resumeUrl) { %>
                                                <a href="<%= app.resumeUrl %>" target="_blank" class="btn btn-sm btn-light border" style="color: var(--danger);" title="View Resume">
                                                    <i class="bi bi-file-earmark-pdf-fill"></i>
                                                </a>
                                            <% } %>
                                        </div>
                                        
                                        <form action="/applicants/<%= app._id %>/stage" method="POST" class="mt-3 border-top pt-2">
                                            <label class="form-label text-muted small fw-bold mb-1" style="font-size: 0.65rem; text-transform: uppercase;">Move to Stage</label>
                                            <select name="stage" class="form-select form-select-sm border-warning border-opacity-50" style="background-color: var(--cream); font-size: 0.8rem; color: var(--text-dark);" onchange="this.form.submit()">
                                                <% stages.forEach(s => { %>
                                                    <option value="<%= s %>" <%= s === app.stage ? 'selected' : '' %>><%= s %></option>
                                                <% }) %>
                                            </select>
                                        </form>
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <div class="text-center py-4 opacity-50">
                                    <p class="small text-muted fw-bold mb-0">No candidates in this stage</p>
                                </div>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
